{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "0.0.0.0"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.4-nano"
      },
      "userTimezone": "Europe/Berlin"
    }
  },
  "tools": {
    "profile": "full",
    "allow": ["openclaw-google-workspace"],
    "web": {
      "search": {
        "enabled": true,
        "openaiCodex": {
          "enabled": true,
          "mode": "live",
          "userLocation": {
            "country": "DE",
            "city": "Hamburg",
            "timezone": "Europe/Berlin"
          }
        }
      },
      "fetch": {
        "enabled": true
      }
    }
  },
  "plugins": {
    "allow": ["openclaw-google-workspace"],
    "entries": {
      "openclaw-google-workspace": {
        "enabled": true,
        "config": {
          "credentialsPath": "./secrets/google-oauth.json",
          "tokenPath": "./secrets/google-tokens.json",
          "services": {
            "gmail": { "enabled": true },
            "calendar": { "enabled": true },
            "drive": { "enabled": true, "readOnly": false }
          }
        }
      }
    }
  }
}
