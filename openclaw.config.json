{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "0.0.0.0"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.4"
      },
      "userTimezone": "Europe/Berlin"
    }
  },
  "mcp": {
    "servers": {
      "github": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"]
      },
      "google-workspace": {
        "command": "npx",
        "args": ["-y", "@iflow-mcp/mcp-google-workspace"]
      },
      "1password": {
        "command": "npx",
        "args": ["-y", "@takescake/1password-mcp"]
      }
    }
  },
  "tools": {
    "profile": "full",
    "web": {
      "search": {
        "enabled": true,
        "openaiCodex": {
          "enabled": true,
          "mode": "live",
          "userLocation": {
            "country": "DE",
            "city": "Hamburg",
            "timezone": "Europe/Berlin"
          }
        }
      },
      "fetch": {
        "enabled": true
      }
    }
  }
}
